# --- Local PostgreSQL (same URL for both if you are not using a pooler)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/backstage?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/backstage?schema=public"

# --- Supabase (Project Settings → Database → Connection string)
# Use the Transaction pooler URI for DATABASE_URL (port 6543) and Session pooler (port 5432) for DIRECT_URL on IPv4 — see Supabase docs.
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# --- Supabase API + Storage (Project Settings → API)
# Project URL and anon key are safe for the browser; service_role is server-only — never expose as NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket must exist in the same Supabase project (Dashboard → Storage → New bucket).
# Name it “product-media” (public) unless you override:
SUPABASE_STORAGE_BUCKET=product-media

# Public site URL (no trailing slash). Required behind reverse proxy on a non-default port
# so redirects and metadata use :8080 instead of :3001. Example:
# NEXT_PUBLIC_SITE_URL=http://72.61.192.84:8080

# JWT secret (min 32 chars in production; use openssl rand -base64 32)
AUTH_SECRET="development-secret-change-me-32chars-min"

# VPS / PM2 (optional; Next defaults to 3000 if unset — use another port if another app uses 3000)
# PORT=3001

# Optional: transactional / marketing (stubs ok without keys)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
